            }
          }
        },
        {
          "name": "Planifier soutenance – conflit salle ❌",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/soutenances",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Test conflit salle\",\n  \"dateHeure\": \"2026-06-15T09:15:00\",\n  \"dureeMinutes\": 30,\n  \"etudiantId\": 3,\n  \"encadrantId\": 3,\n  \"salleId\": 1\n}"
            }
          }
        },
        {
          "name": "Planifier soutenance – conflit encadrant ❌",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/soutenances",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Test conflit encadrant\",\n  \"dateHeure\": \"2026-06-15T09:00:00\",\n  \"dureeMinutes\": 30,\n  \"etudiantId\": 3,\n  \"encadrantId\": 1,\n  \"salleId\": 3\n}"
            }
          }
        },
        {
          "name": "Consulter soutenance par ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/soutenances/1"
          }
        },
        {
          "name": "Soutenances d'un étudiant",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/soutenances/etudiant/1"
          }
        },
        {
          "name": "Modifier soutenance",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/soutenances/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Titre modifié\",\n  \"dateHeure\": \"2026-06-15T09:00:00\",\n  \"dureeMinutes\": 45,\n  \"etudiantId\": 1,\n  \"encadrantId\": 1,\n  \"salleId\": 1\n}"
            }
          }
        },
        {
          "name": "Changer statut → EN_COURS",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/soutenances/1/statut?statut=EN_COURS",
              "query": [{ "key": "statut", "value": "EN_COURS" }]
            }
          }
        },
        {
          "name": "Changer statut → TERMINEE",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/soutenances/1/statut?statut=TERMINEE",
              "query": [{ "key": "statut", "value": "TERMINEE" }]
            }
          }
        }
      ]
