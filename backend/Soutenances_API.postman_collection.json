          "name": "Créer étudiant 1",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/etudiants",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Bensalem\",\n  \"prenom\": \"Walid\",\n  \"email\": \"walid.bensalem@univ.dz\",\n  \"matricule\": \"20210010\",\n  \"filiere\": \"Informatique\",\n  \"niveau\": \"M2\"\n}"
