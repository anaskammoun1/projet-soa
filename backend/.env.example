# Backend runtime
SERVER_PORT=8080

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=soutenances_db
DB_USERNAME=root
DB_PASSWORD=change_me

# JPA options: validate | update | create | create-drop | none
JPA_DDL_AUTO=update

# JWT auth
# Use a long random value in real environments.
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# First admin bootstrap
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=change_me_before_first_run

# Optional local demo data seed
DEMO_DATA_ENABLED=false
DEMO_USER_PASSWORD=change_me_for_demo_users
DEMO_SEED_NOTES=true
